# AI Agents Server Configuration
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env

# Ports (4000-5000 range)
BACKEND_PORT=4700
FRONTEND_PORT=4200
POSTGRES_PORT=4532
REDIS_PORT=4379
CHROMADB_PORT=4800

# PostgreSQL
POSTGRES_USER=agents
POSTGRES_PASSWORD=agents_secret_2026
POSTGRES_DB=ai_agents

# Redis
REDIS_PASSWORD=redis_secret_2026

# JWT (CHANGE IN PRODUCTION!)
JWT_SECRET_KEY=super-secret-jwt-key-change-in-production-2026
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Default admin (CHANGE IN PRODUCTION!)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# Ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ChromaDB
CHROMADB_HOST=chromadb
CHROMADB_PORT_INTERNAL=8000

# MongoDB
MONGO_PORT=4717
MONGO_USER=agents
MONGO_PASSWORD=mongo_secret_2026
MONGO_DB=ai_agents
